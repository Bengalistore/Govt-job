# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/jobportal?retryWrites=true&w=majority

# Admin panel login
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password

# Random long secret string used to sign admin login tokens
JWT_SECRET=replace-with-a-long-random-string

# Public site URL (used for SEO tags + sitemap). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://yourdomain.vercel.app
